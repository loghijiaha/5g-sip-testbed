FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    git build-essential cmake libsctp-dev lksctp-tools \
    iproute2 baresip iputils-ping net-tools \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 --branch v3.2.6 https://github.com/aligungr/UERANSIM.git /ueransim

WORKDIR /ueransim
RUN make

ENV PATH="/ueransim/build:${PATH}"

CMD ["bash"]
